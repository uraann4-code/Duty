{
  "entities": {
    "Employee": {
      "title": "Employee",
      "description": "Office staff member",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "dutyCount": { "type": "number", "description": "Total number of duties performed" },
        "lastDutyDate": { "type": "string", "format": "date-time", "description": "Date of the last assigned duty" },
        "isActive": { "type": "boolean" }
      },
      "required": ["id", "name", "dutyCount"]
    },
    "DutyAssignment": {
      "title": "Duty Assignment",
      "description": "Assignment of staff to a specific block on a specific date",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date", "description": "ISO date string" },
        "block": { "type": "string", "enum": ["Sir Syed", "Business School", "NC", "XC"] },
        "staffIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "date", "block", "staffIds"]
    }
  },
  "firestore": {
    "employees": {
      "schema": "Employee",
      "description": "Collection of all office employees"
    },
    "duties": {
      "schema": "DutyAssignment",
      "description": "Collection of all duty assignments"
    }
  }
}
